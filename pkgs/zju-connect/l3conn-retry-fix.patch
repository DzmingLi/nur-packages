+
+// Relogin re-authenticates with the server and refreshes the token. It is
+// safe to call concurrently — the mutex serialises attempts, and a debounce
+// window collapses bursty calls (multiple in-flight L3Conn goroutines all
+// noticing the dead token at once) into a single login round-trip.
+//
+// Resources / line list / client IP are left as-is: only twfID and token
+// are refreshed, since those are the parts the server invalidates when it
+// kicks our session.
+func (c *Client) Relogin() error {
+	c.loginMu.Lock()
+	defer c.loginMu.Unlock()
+
+	// If another goroutine just refreshed credentials, skip.
+	if !c.lastLoginAt.IsZero() && time.Since(c.lastLoginAt) < 10*time.Second {
+		log.Printf("Re-login: another goroutine refreshed credentials %.1fs ago, skipping", time.Since(c.lastLoginAt).Seconds())
+		return nil
+	}
+
+	log.Printf("Re-login: refreshing TwfID and token")
+	c.twfID = ""
+	c.token = nil
+
+	if err := c.requestTwfID(c.graphCodeFile); err != nil {
+		return err
+	}
+	if err := c.requestToken(); err != nil {
+		return err
+	}
+
+	c.lastLoginAt = time.Now()
+	log.Printf("Re-login succeeded")
 	return nil
 }
