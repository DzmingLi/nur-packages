+// Relogin refreshes credentials when the tunnel server rejects the cached
+// token. It is safe to call concurrently — the mutex serialises attempts,
+// and a debounce window collapses bursty calls (multiple in-flight L3Conn
+// goroutines all noticing the dead token at once) into a single round-trip.
+//
+// Strategy: in most cases the long-lived TwfID (login session cookie) is
+// still valid — only the short-lived per-tunnel token is stale. Try
+// requestToken alone first; that hits a single endpoint with the existing
+// TwfID Cookie and gets a fresh sessionID/token without going through the
+// full username/password/2FA flow. Only fall back to a full re-login (which
+// may prompt for SMS / TOTP / captcha) if that token refresh fails — in
+// that case the TwfID itself has expired and full re-auth is unavoidable.
+//
+// Resources / line list / client IP are left untouched throughout.
+func (c *Client) Relogin() error {
+	c.loginMu.Lock()
+	defer c.loginMu.Unlock()
+
+	// If another goroutine just refreshed credentials, skip.
+	if !c.lastLoginAt.IsZero() && time.Since(c.lastLoginAt) < 10*time.Second {
+		log.Printf("Re-login: another goroutine refreshed credentials %.1fs ago, skipping", time.Since(c.lastLoginAt).Seconds())
+		return nil
+	}
+
+	// Fast path: try a token-only refresh using existing TwfID (no 2FA).
+	// We don't call requestIP here — same TwfID means same server-side
+	// session, so the assigned client IP (and thus c.ipReverse used by
+	// the SendConn/RecvConn handshake) doesn't change. Calling requestIP
+	// against an already-assigned session actually fails with
+	// "unexpected request IP reply" and would force us into the slow path.
+	if c.twfID != "" {
+		log.Printf("Re-login: refreshing token via existing TwfID")
+		if err := c.requestToken(); err != nil {
+			log.Printf("Re-login: token refresh failed, falling back to full re-auth: %v", err)
+		} else {
+			c.lastLoginAt = time.Now()
+			log.Printf("Re-login: token refresh succeeded (no re-auth needed)")
+			return nil
+		}
+	}
+
+	// Slow path: TwfID expired (or never was set). Re-auth from scratch.
+	// This may prompt for SMS / TOTP / captcha if the server requires it.
+	// Note: we don't pre-null c.twfID or c.token — requestTwfID / requestToken
+	// overwrite them on success, and on failure we'd rather keep stale-but-
+	// non-nil values than risk a "token is nil" panic in concurrent SendConn
+	// calls that arrive while we're failing.
+	log.Printf("Re-login: full re-auth (refreshing TwfID + token)")
+	if err := c.requestTwfID(c.graphCodeFile); err != nil {
+		return err
+	}
+	if err := c.requestToken(); err != nil {
+		return err
+	}
+	if err := c.requestIP(); err != nil {
+		return err
+	}
+
+	c.lastLoginAt = time.Now()
+	log.Printf("Re-login: full re-auth succeeded")
 	return nil
 }
