 	"github.com/mythologyli/zju-connect/log"
 	"github.com/refraction-networking/utls"
 )
 
+// sslKeyLogWriter is shared between all TLS configs. When SSLKEYLOGFILE env
+// is set at startup, every TLS handshake logs its session keys in NSS Key Log
+// Format, so Wireshark can decrypt captured traffic. Nil disables key logging.
+var sslKeyLogWriter io.Writer
+
+func init() {
+	if path := os.Getenv("SSLKEYLOGFILE"); path != "" {
+		f, err := os.OpenFile(path, os.O_WRONLY|os.O_CREATE|os.O_APPEND, 0644)
+		if err != nil {
+			log.Printf("SSLKEYLOGFILE: open %s failed: %v", path, err)
+			return
+		}
+		sslKeyLogWriter = f
+		log.Printf("SSLKEYLOGFILE: writing TLS keys to %s", path)
+	}
+}
